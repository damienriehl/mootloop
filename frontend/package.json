{
  "name": "mootloop-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev -p 8730",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:gen": "openapi-typescript ../openapi.json -o lib/api/schema.d.ts",
    "openapi:check": "openapi-typescript ../openapi.json -o /tmp/mootloop-schema.check.d.ts && diff -u lib/api/schema.d.ts /tmp/mootloop-schema.check.d.ts"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.62.0",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "next": "^16.2.2",
    "openapi-fetch": "^0.13.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.2",
    "jsdom": "^28.1.0",
    "msw": "^2.7.0",
    "openapi-typescript": "^7.5.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
