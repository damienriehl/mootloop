# Matter data NEVER lives in the repo (vault-boundary rule; backstop only).
# Anchored to the repo root so it ignores the top-level vault dir only — not
# source paths that happen to contain "matters" (e.g. frontend/app/matters routes).
/matters/

# Secrets
.env
secrets.env

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
