# MootLoop matter-tier DRIVER worker (plan FE-1) — drains runs by shelling out to the
# headless `claude` CLI, sandboxed. No web surface, no published ports. Matter data
# never lives in the image: the live vaults are mounted at runtime.

FROM python:3.12-slim

LABEL org.opencontainers.image.title="mootloop-driver" \
      org.opencontainers.image.description="MootLoop hosted engine worker — headless Claude turns under a bubblewrap egress jail" \
      org.opencontainers.image.source="https://github.com/damienriehl/mootloop" \
      org.opencontainers.image.licenses="MIT"

# System deps:
#  - bubblewrap: the `egress_wrapper` network jail prepended to the claude argv
#    (engine/claude_provider.py) — personas run with no outbound network.
#  - pandoc: export/docx_render.py shells to it to render DOCX deliverables.
#  - curl, ca-certificates: TLS roots for the operator's subscription auth path.
#  - procps: cheap pgrep liveness probe for the worker.
RUN apt-get update && apt-get install -y --no-install-recommends \
    bubblewrap \
    ca-certificates \
    curl \
    pandoc \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Node 22 (+ npm) copied from the official slim image — no nodesource apt repo needed.
COPY --from=node:22-slim /usr/local/bin/node /usr/local/bin/node
COPY --from=node:22-slim /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx

# Headless Claude Code CLI, pinned to an exact version (the persona turn runtime).
# DISABLE_AUTOUPDATER stops it mutating itself in the sealed image.
ENV DISABLE_AUTOUPDATER=1
RUN npm install -g @anthropic-ai/claude-code@2.1.207 \
    && npm cache clean --force

# uv via the official binary (mirrors the demo Dockerfile).
COPY --from=ghcr.io/astral-sh/uv:0.5.11 /uv /usr/local/bin/uv

WORKDIR /app

# Base deps only — fastapi/uvicorn live behind the `web` extra and the engine/CLI
# `driver serve` path never imports them (verified: fastapi is confined to
# mootloop.web.*). pandoc/bubblewrap are system deps, not Python.
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

COPY . .
RUN uv sync --frozen --no-dev

ENV PATH="/app/.venv/bin:$PATH"

# Non-root service user, UID/GID 3200 — matches the host `mootloop` user that owns the
# mounted /srv/mootloop-matters and ~/.mootloop/secrets.env. HOME anchors the secrets
# loader (SECRETS_FILE -> ~/.mootloop/secrets.env: subscription token lives there).
RUN groupadd --gid 3200 mootloop \
    && useradd --uid 3200 --gid 3200 --home-dir /home/mootloop --create-home mootloop \
    && chown -R mootloop:mootloop /app
ENV HOME=/home/mootloop
USER mootloop

# Cheap worker liveness: the supervised serve loop must be running.
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD pgrep -f "driver serve" >/dev/null || exit 1

# The supervised loop drains the current turn on SIGTERM (compose stop_grace_period
# must exceed the 600s turn timeout — see docker-compose.matter.yaml).
CMD ["sh", "-c", "mootloop driver serve --matters-root /srv/mootloop-matters --worker-id ${MOOTLOOP_WORKER_ID:-driver-1}"]
